<Window x:Class="EmployeeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EmployeeApp.ViewModels"
        Title="Учёт сотрудников"
        Height="540"
        Width="840"
        Background="#F4F4F4">

    <Window.DataContext>
        <vm:EmployeeViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate x:Key="EmployeeCardTemplate">
            <Border Background="White"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="10"
                    Margin="2">
                <StackPanel>
                    <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding Position, Mode=OneWay}"
                               FontSize="12" Foreground="#2E86C1"/>
                    <TextBlock FontSize="11" Foreground="Gray">
                        <Run Text="Отдел: "/>
                        <Run Text="{Binding Department, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="Gray">
                        <Run Text="Оклад: "/>
                        <Run Text="{Binding Salary}"/>
                        <Run Text=" руб."/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DataTemplate>

        <ControlTemplate x:Key="AddButtonTemplate" TargetType="Button">
            <Border x:Name="border" Background="#28B463" CornerRadius="14" Padding="14,6">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="+" FontSize="18" FontWeight="Bold"
                               Foreground="White" Margin="0,0,6,0"/>
                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#1E8449"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#196F3D"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding AddEmployeeCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding EditEmployeeCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DeleteEmployeeCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteEmployeeCommand}"/>
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="Перезагрузить" InputGestureText="F5"
                          Command="{Binding ReloadCommand}"/>
                <Separator/>
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Сотрудники">
                <MenuItem Header="Добавить" InputGestureText="Ctrl+N"
                          Command="{Binding AddEmployeeCommand}"/>
                <MenuItem Header="Редактировать" InputGestureText="Ctrl+E"
                          Command="{Binding EditEmployeeCommand}"/>
                <MenuItem Header="Удалить" InputGestureText="Ctrl+D"
                          Command="{Binding DeleteEmployeeCommand}"/>
            </MenuItem>
            <MenuItem Header="_Отчёты">
                <MenuItem Header="Список сотрудников" Click="ReportList_Click"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Добавить сотрудника"
                        Foreground="White" FontWeight="Bold" Margin="2"
                        ToolTip="Ctrl+N"
                        Template="{StaticResource AddButtonTemplate}"
                        Command="{Binding AddEmployeeCommand}"/>
                <Button Content="Редактировать" Padding="8,2" ToolTip="Ctrl+E"
                        Command="{Binding EditEmployeeCommand}"/>
                <Button Content="Удалить" Padding="8,2" ToolTip="Ctrl+D"
                        Command="{Binding DeleteEmployeeCommand}"/>
                <Separator/>
                <Button Content="Перезагрузить" Padding="8,2" ToolTip="F5"
                        Command="{Binding ReloadCommand}"/>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="Всего: "/>
            <TextBlock Text="{Binding Employees.Count}"/>
            <Separator/>
            <TextBlock Text="Отображено: "/>
            <TextBlock Text="{Binding FilteredEmployees.Count}"/>
            <Separator/>
            <TextBlock Text="Загрузка..."
                       Foreground="#C0392B"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
        </StatusBar>

        <Grid>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="5">
                    <GroupBox Header="Фильтр по отделу" Padding="10">
                        <ComboBox ItemsSource="{Binding FilterOptions}"
                                  SelectedItem="{Binding FilterDepartment, Mode=TwoWay}"
                                  Height="26"/>
                    </GroupBox>

                    <GroupBox Header="Выбранный сотрудник" Padding="10" Margin="0,10,0,0">
                        <StackPanel DataContext="{Binding SelectedEmployee}">
                            <TextBlock Text="ФИО:" FontWeight="Bold"/>
                            <TextBox Text="{Binding FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,2,0,8"/>
                            <TextBlock Text="Должность (только чтение):" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Position, Mode=OneWay}"
                                       Foreground="#2E86C1" FontSize="13" Margin="0,2,0,8"/>
                            <TextBlock Text="Оклад:" FontWeight="Bold"/>
                            <TextBox Text="{Binding Salary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,2,0,0"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>

                <ListBox x:Name="EmployeeListBox"
                         Grid.Column="1"
                         Margin="5"
                         ItemsSource="{Binding FilteredEmployees}"
                         SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
                         ItemTemplate="{StaticResource EmployeeCardTemplate}"/>
            </Grid>

            <!-- Оверлей с ProgressBar на время асинхронной загрузки -->
            <Border Background="#80FFFFFF"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Загрузка данных..."
                               FontSize="16"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <ProgressBar IsIndeterminate="True"
                                 Width="260"
                                 Height="20"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
