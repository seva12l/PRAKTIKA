<Window x:Class="EmployeeApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="540"
        Width="820"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource LoginBgBrush}"
        FontFamily="Segoe UI"
        Opacity="0">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <StackPanel VerticalAlignment="Center" Margin="56,0">
                <Border Width="74" Height="74" CornerRadius="20" Background="#33FFFFFF"
                        HorizontalAlignment="Left" Margin="0,0,0,22">
                    <Path Width="40" Height="40" Stretch="Uniform" Fill="White"
                          Data="M12,12 C14.21,12 16,10.21 16,8 C16,5.79 14.21,4 12,4 C9.79,4 8,5.79 8,8 C8,10.21 9.79,12 12,12 Z M12,14 C9.33,14 4,15.34 4,18 L4,20 L20,20 L20,18 C20,15.34 14.67,14 12,14 Z"/>
                </Border>
                <TextBlock Text="Учёт сотрудников" Foreground="White"
                           FontSize="34" FontWeight="Bold"/>
                <TextBlock Text="Современная система управления персоналом"
                           Foreground="#E0E7FF" FontSize="14" Margin="0,10,0,0" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                    <Border Background="#33FFFFFF" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                        <TextBlock Text="WPF" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#33FFFFFF" CornerRadius="8" Padding="10,5" Margin="0,0,8,0">
                        <TextBlock Text=".NET 9" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#33FFFFFF" CornerRadius="8" Padding="10,5">
                        <TextBlock Text="MVVM" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Border Grid.Column="1" Background="White" CornerRadius="20,0,0,20">
            <StackPanel Margin="44,0" VerticalAlignment="Center">
                <TextBlock Text="Добро пожаловать" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="Войдите в свою учётную запись" FontSize="13"
                           Foreground="{StaticResource MutedBrush}" Margin="0,4,0,24"/>

                <TextBlock Text="ЛОГИН" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="LoginBox" Margin="0,5,0,14"/>

                <TextBlock Text="ПАРОЛЬ" Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,5,0,14"/>

                <TextBlock Text="ОТДЕЛ (ДЛЯ РЕГИСТРАЦИИ)" Style="{StaticResource LabelStyle}"/>
                <ComboBox x:Name="DepartmentBox" Margin="0,5,0,8" SelectedIndex="0">
                    <ComboBoxItem Content="Управление"/>
                    <ComboBoxItem Content="Разработка"/>
                    <ComboBoxItem Content="Финансы"/>
                    <ComboBoxItem Content="Дизайн"/>
                </ComboBox>

                <TextBlock x:Name="ErrorText" Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap" Margin="0,8,0,0" FontSize="12"/>

                <Button Content="Войти" Style="{StaticResource PrimaryButtonStyle}"
                        Height="42" Margin="0,16,0,0" IsDefault="True" Click="LoginButton_Click"/>
                <Button Content="Регистрация" Style="{StaticResource GhostButtonStyle}"
                        Height="42" Margin="0,10,0,0" Click="RegisterButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
