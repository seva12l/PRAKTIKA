<Window x:Class="EmployeeApp.ScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Уведомление о расписании"
        Height="220"
        Width="420"
        Background="#F4F4F4"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Текст уведомления:" FontWeight="Bold"/>
        <TextBox x:Name="TextField" Margin="0,5,0,10" Height="80"
                 AcceptsReturn="True" TextWrapping="Wrap"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отправить всем" Width="140" Height="30" Margin="0,0,10,0"
                    Background="#2E86C1" Foreground="White"
                    Click="OkButton_Click" IsDefault="True"/>
            <Button Content="Отмена" Width="100" Height="30"
                    Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
