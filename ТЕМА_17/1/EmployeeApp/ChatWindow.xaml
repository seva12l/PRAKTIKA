<Window x:Class="EmployeeApp.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чат между отделами"
        Height="580"
        Width="680"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Opacity="0">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Чат между отделами" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="Сообщения передаются через Named Pipes" Foreground="#E0E7FF" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="ОТДЕЛ-ПОЛУЧАТЕЛЬ" Foreground="#E0E7FF" FontSize="10" FontWeight="SemiBold"/>
                    <ComboBox x:Name="DepartmentBox" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" Margin="16" CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
            <ListBox x:Name="MessagesList" Background="Transparent" BorderThickness="0" Padding="6">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F4F6FA" CornerRadius="10" Padding="12,8" Margin="0,3">
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

        <Border Grid.Row="2" Background="White" Padding="16,14" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" x:Name="MessageBox" KeyDown="MessageBox_KeyDown"/>
                <Button Grid.Column="1" Content="Отправить" Width="130" Height="40"
                        Margin="10,0,0,0" Style="{StaticResource PrimaryButtonStyle}"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
