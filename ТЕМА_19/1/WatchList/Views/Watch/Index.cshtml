@model List<WatchList.Models.WatchItem>
@using WatchList.Models
@{
    ViewData["Title"] = "Мой список";
    var current = (WatchStatus?)ViewBag.CurrentStatus;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="m-0">Мой WatchList</h2>
    <a class="btn btn-primary" asp-action="Add">Добавить</a>
</div>

<ul class="nav nav-pills mb-4">
    <li class="nav-item">
        <a class="nav-link @(current == null ? "active" : "")" asp-action="Index">Все</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(current == WatchStatus.Planned ? "active" : "")" asp-action="Index" asp-route-status="@WatchStatus.Planned">Запланировано</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(current == WatchStatus.Watching ? "active" : "")" asp-action="Index" asp-route-status="@WatchStatus.Watching">Смотрю</a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(current == WatchStatus.Watched ? "active" : "")" asp-action="Index" asp-route-status="@WatchStatus.Watched">Просмотрено</a>
    </li>
</ul>

@if (!Model.Any())
{
    <div class="alert alert-info">Список пуст. Добавьте первый фильм или сериал.</div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var item in Model)
        {
            string badge = item.Status switch
            {
                WatchStatus.Planned => "bg-secondary",
                WatchStatus.Watching => "bg-warning text-dark",
                WatchStatus.Watched => "bg-success",
                _ => "bg-light"
            };
            string statusText = item.Status switch
            {
                WatchStatus.Planned => "Запланировано",
                WatchStatus.Watching => "Смотрю",
                WatchStatus.Watched => "Просмотрено",
                _ => item.Status.ToString()
            };
            string typeText = item.Type == WatchType.Movie ? "Фильм" : "Сериал";

            <div class="col">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title mb-2">@item.Title</h5>
                            <span class="badge @badge">@statusText</span>
                        </div>
                        <p class="card-text text-muted mb-1"><small>@typeText · @item.DateAdded.ToShortDateString()</small></p>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex gap-2">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">Подробнее</a>
                        @if (item.Status != WatchStatus.Watched)
                        {
                            <a class="btn btn-sm btn-success" asp-action="MarkAsWatched" asp-route-id="@item.Id">Просмотрено</a>
                        }
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="ms-auto">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
