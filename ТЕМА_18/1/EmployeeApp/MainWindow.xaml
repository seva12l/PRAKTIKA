<Window x:Class="EmployeeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EmployeeApp.ViewModels"
        xmlns:local="clr-namespace:EmployeeApp"
        Title="Учёт сотрудников"
        Height="700"
        Width="1120"
        MinHeight="580"
        MinWidth="960"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Opacity="0">

    <Window.DataContext>
        <vm:EmployeeViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate x:Key="EmployeeCardTemplate">
            <Border Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14"
                    Margin="6">
                <Border.Effect>
                    <DropShadowEffect Color="#22000000" BlurRadius="10" ShadowDepth="1" Opacity="0.15"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Width="48" Height="48" Margin="0,0,14,0">
                        <Ellipse Fill="{StaticResource HeaderBrush}"/>
                        <TextBlock Text="{Binding Initials}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                        <TextBlock Text="{Binding Position}" FontSize="12"
                                   Foreground="{StaticResource PrimaryBrush}" Margin="0,3,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock Text="Отдел:" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding Department}" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}" Margin="0,0,12,0"/>
                            <TextBlock Text="Оклад:" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,4,0"/>
                            <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}">
                                <Run Text="{Binding Salary}"/>
                                <Run Text="₽"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Column="2" Width="34" Height="34" Margin="10,0,0,0"
                          local:StatusAnimation.IsAvailable="{Binding IsAvailable}"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Ellipse>
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                            <Setter Property="Fill" Value="{StaticResource DangerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <Path Stroke="White" StrokeThickness="2.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Width="18" Height="18" Stretch="Uniform">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Data" Value="M2,10 L8,16 L18,4"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                            <Setter Property="Data" Value="M5,5 L15,15 M15,5 L5,15"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <Style TargetType="ListBoxItem" x:Key="AnimatedItemStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#F5F7FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#DCFCE7"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding AddEmployeeCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding EditEmployeeCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DeleteEmployeeCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteEmployeeCommand}"/>
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="F" Modifiers="Control" Command="{x:Static local:MainWindow.FocusSearchCommand}"/>
    </Window.InputBindings>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBrush}" Padding="22,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Учёт сотрудников"
                               FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock FontSize="12" Foreground="#E0E7FF" Margin="0,2,0,0">
                        <Run Text="Пользователь:"/>
                        <Run Text="{Binding CurrentUserInfo, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Чат" Style="{StaticResource HeaderGhostButtonStyle}"
                            Margin="0,0,8,0" Command="{Binding OpenChatCommand}"/>
                    <Button Content="Уведомление" Style="{StaticResource HeaderGhostButtonStyle}"
                            Margin="0,0,8,0" Command="{Binding PublishScheduleCommand}"/>
                    <Button Content="О программе" Style="{StaticResource HeaderGhostButtonStyle}"
                            Click="About_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <TextBox x:Name="SearchBox"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="38,9,12,9"/>
                        <Path Width="14" Height="14" Margin="14,0,0,0"
                              Stretch="Uniform"
                              Stroke="{StaticResource MutedBrush}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M9,9 L13,13 M5.5,1 A4.5,4.5 0 1 1 5.5,10 A4.5,4.5 0 1 1 5.5,1"
                              VerticalAlignment="Center" HorizontalAlignment="Left"
                              IsHitTestVisible="False"/>
                        <TextBlock Text="Поиск сотрудника..." FontSize="13" Margin="38,0,0,0"
                                   VerticalAlignment="Center" IsHitTestVisible="False"
                                   Foreground="{StaticResource MutedBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
                                    <Setter Property="FontFamily" Value="Segoe UI"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <ComboBox Grid.Column="1"
                              Style="{StaticResource ModernComboBoxStyle}"
                              ItemsSource="{Binding FilterOptions}"
                              SelectedItem="{Binding FilterDepartment, Mode=TwoWay}"/>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="14,0,0,0">
                    <Button Content="Добавить" Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,0,8,0" Command="{Binding AddEmployeeCommand}"
                            ToolTip="Ctrl+N"/>
                    <Button Content="Изменить" Style="{StaticResource GhostButtonStyle}"
                            Margin="0,0,8,0" Command="{Binding EditEmployeeCommand}"
                            ToolTip="Ctrl+E"/>
                    <Button Content="Удалить" Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding DeleteEmployeeCommand}"
                            ToolTip="Ctrl+D"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="22,18,22,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="6">
                <Grid>
                    <ListBox x:Name="EmployeesList"
                             ItemsSource="{Binding FilteredEmployees}"
                             SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
                             ItemTemplate="{StaticResource EmployeeCardTemplate}"
                             ItemContainerStyle="{StaticResource AnimatedItemStyle}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="False"/>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                IsHitTestVisible="False">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilteredEmployees.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Ничего не найдено" FontSize="15" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                        <TextBlock Text="Измените запрос или фильтр" FontSize="12" Margin="0,4,0,0"
                                   HorizontalAlignment="Center" Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="16,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="ProfileCard" Grid.Row="0" Style="{StaticResource CardBorderStyle}"
                        Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,14"
                        RenderTransformOrigin="0.5,0">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                            <TranslateTransform X="0" Y="0"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <StackPanel DataContext="{Binding SelectedEmployee}">
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="62" Height="62" Margin="0,0,14,0">
                                <Ellipse Fill="{StaticResource HeaderBrush}"/>
                                <TextBlock Text="{Binding Initials}" Foreground="White"
                                           FontWeight="Bold" FontSize="22"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="15"/>
                                <TextBlock Text="{Binding Position}" Foreground="{StaticResource PrimaryBrush}" Margin="0,3,0,0"/>
                                <Border CornerRadius="10" Padding="10,4" Margin="0,6,0,0" HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#DCFCE7"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding StatusText}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#15803D"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAvailable}" Value="False">
                                                        <Setter Property="Foreground" Value="#B91C1C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="ФИО" Style="{StaticResource LabelStyle}"/>
                        <TextBox Margin="0,5,0,12"
                                 Text="{Binding FullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="ОТДЕЛ" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Department}" FontSize="13" Margin="0,5,0,12"/>

                        <TextBlock Text="ОКЛАД, ₽" Style="{StaticResource LabelStyle}"/>
                        <TextBox Margin="0,5,0,12"
                                 Text="{Binding Salary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <Button Content="Переключить статус"
                                Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Command="{Binding DataContext.ToggleAvailabilityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Уведомления" FontWeight="Bold"
                                   FontSize="13" Margin="0,0,0,10"/>
                        <ListBox ItemsSource="{Binding NotificationLog}" Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F4F6FA" CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="22,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Всего: " Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock Text="{Binding Employees.Count}" FontWeight="SemiBold"/>
                    <TextBlock Text="     Показано: " Foreground="{StaticResource MutedBrush}"/>
                    <TextBlock Text="{Binding FilteredEmployees.Count}" FontWeight="SemiBold"/>
                    <TextBlock Margin="14,0,0,0" Foreground="{StaticResource PrimaryBrush}"
                               Text="{Binding StatusMessage}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="6"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                 Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Button Content="Сохранить" Style="{StaticResource GhostButtonStyle}"
                            Margin="0,0,8,0" Command="{Binding SaveCommand}" ToolTip="Ctrl+S"/>
                    <Button Content="Обновить" Style="{StaticResource GhostButtonStyle}"
                            Command="{Binding ReloadCommand}" ToolTip="F5"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
