<Window x:Class="EmployeeApp.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод"
        Height="220"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        FontFamily="Segoe UI"
        Opacity="0">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <StackPanel Margin="22">
        <TextBlock x:Name="PromptText" FontWeight="SemiBold" Margin="0,0,0,10"/>
        <TextBox x:Name="InputBox"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Отмена" Width="110" Height="38" Margin="0,0,10,0"
                    Style="{StaticResource GhostButtonStyle}" Click="CancelClick"/>
            <Button Content="OK" Width="110" Height="38" IsDefault="True"
                    Style="{StaticResource PrimaryButtonStyle}" Click="OkClick"/>
        </StackPanel>
    </StackPanel>
</Window>
