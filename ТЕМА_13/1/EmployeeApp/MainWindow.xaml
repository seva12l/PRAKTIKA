<Window x:Class="EmployeeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:EmployeeApp"
        Title="Учёт сотрудников"
        Height="500"
        Width="800"
        Background="#F4F4F4">

    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding AddEmployeeCommand}"/>
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding EditEmployeeCommand}"/>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DeleteEmployeeCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteEmployeeCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Сотрудники">
                <MenuItem Header="Добавить" InputGestureText="Ctrl+N"
                          Command="{Binding AddEmployeeCommand}"/>
                <MenuItem Header="Редактировать" InputGestureText="Ctrl+E"
                          Command="{Binding EditEmployeeCommand}"/>
                <MenuItem Header="Удалить" InputGestureText="Ctrl+D"
                          Command="{Binding DeleteEmployeeCommand}"/>
            </MenuItem>
            <MenuItem Header="_Отчёты">
                <MenuItem Header="Список сотрудников" Click="ReportList_Click"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="Добавить"
                        ToolTip="Добавить сотрудника (Ctrl+N)"
                        Padding="8,2"
                        Command="{Binding AddEmployeeCommand}"
                        Click="AddButton_Click"/>
                <Button Content="Редактировать"
                        ToolTip="Редактировать сотрудника (Ctrl+E)"
                        Padding="8,2"
                        Command="{Binding EditEmployeeCommand}"
                        Click="EditButton_Click"/>
                <Button Content="Удалить"
                        ToolTip="Удалить сотрудника (Ctrl+D)"
                        Padding="8,2"
                        Command="{Binding DeleteEmployeeCommand}"
                        Click="DeleteButton_Click"/>
            </ToolBar>
        </ToolBarTray>

        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="Всего сотрудников: "/>
            <TextBlock Text="{Binding Employees.Count}"/>
        </StatusBar>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0"
                      Header="Фильтр по должности"
                      Margin="5"
                      Padding="10">
                <StackPanel>
                    <RadioButton Content="Все" IsChecked="True"
                                 GroupName="PositionFilter" Margin="0,4"
                                 Checked="Filter_Checked" Tag="Все"/>
                    <RadioButton Content="Менеджер"
                                 GroupName="PositionFilter" Margin="0,4"
                                 Checked="Filter_Checked" Tag="Менеджер"/>
                    <RadioButton Content="Разработчик"
                                 GroupName="PositionFilter" Margin="0,4"
                                 Checked="Filter_Checked" Tag="Разработчик"/>
                    <RadioButton Content="Бухгалтер"
                                 GroupName="PositionFilter" Margin="0,4"
                                 Checked="Filter_Checked" Tag="Бухгалтер"/>
                    <RadioButton Content="Дизайнер"
                                 GroupName="PositionFilter" Margin="0,4"
                                 Checked="Filter_Checked" Tag="Дизайнер"/>
                </StackPanel>
            </GroupBox>

            <ListBox x:Name="EmployeeListBox"
                     Grid.Column="1"
                     Margin="5"
                     ItemsSource="{Binding FilteredEmployees}"
                     SelectedItem="{Binding SelectedEmployee}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="{Binding Position}" FontSize="12" Foreground="Gray"/>
                            <TextBlock FontSize="12">
                                <Run Text="Оклад: "/>
                                <Run Text="{Binding Salary}"/>
                                <Run Text=" руб."/>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </DockPanel>
</Window>
