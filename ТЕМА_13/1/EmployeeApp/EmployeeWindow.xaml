<Window x:Class="EmployeeApp.EmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сотрудник"
        Height="320"
        Width="380"
        Background="#F4F4F4"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock Text="ФИО" FontWeight="Bold"/>
        <TextBox x:Name="FullNameBox" Margin="0,5,0,10" Height="25"/>

        <TextBlock Text="Должность" FontWeight="Bold"/>
        <ComboBox x:Name="PositionBox" Margin="0,5,0,10" Height="25">
            <ComboBoxItem Content="Менеджер"/>
            <ComboBoxItem Content="Разработчик"/>
            <ComboBoxItem Content="Бухгалтер"/>
            <ComboBoxItem Content="Дизайнер"/>
        </ComboBox>

        <TextBlock Text="Оклад" FontWeight="Bold"/>
        <TextBox x:Name="SalaryBox" Margin="0,5,0,20" Height="25"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить"
                    Width="100"
                    Height="30"
                    Margin="0,0,10,0"
                    Background="#2E86C1"
                    Foreground="White"
                    Click="SaveButton_Click"/>
            <Button Content="Отмена"
                    Width="100"
                    Height="30"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
