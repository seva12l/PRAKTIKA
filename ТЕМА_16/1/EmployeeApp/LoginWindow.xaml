<Window x:Class="EmployeeApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="360"
        Width="380"
        Background="#F4F4F4"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <StackPanel Margin="20">
        <TextBlock Text="Учёт сотрудников"
                   FontSize="18" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <TextBlock Text="Логин" FontWeight="Bold"/>
        <TextBox x:Name="LoginBox" Margin="0,5,0,10" Height="25"/>

        <TextBlock Text="Пароль" FontWeight="Bold"/>
        <PasswordBox x:Name="PasswordBox" Margin="0,5,0,10" Height="25"/>

        <TextBlock Text="Отдел (для регистрации)" FontWeight="Bold"/>
        <ComboBox x:Name="DepartmentBox" Margin="0,5,0,10" Height="25" SelectedIndex="0">
            <ComboBoxItem Content="Управление"/>
            <ComboBoxItem Content="Разработка"/>
            <ComboBoxItem Content="Финансы"/>
            <ComboBoxItem Content="Дизайн"/>
        </ComboBox>

        <TextBlock x:Name="ErrorText" Foreground="#C0392B"
                   TextWrapping="Wrap" Margin="0,4,0,4"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Регистрация" Width="110" Height="30" Margin="0,0,10,0"
                    Click="RegisterButton_Click"/>
            <Button Content="Войти" Width="110" Height="30"
                    Background="#2E86C1" Foreground="White"
                    Click="LoginButton_Click" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
