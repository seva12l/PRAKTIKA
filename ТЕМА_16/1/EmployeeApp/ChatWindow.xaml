<Window x:Class="EmployeeApp.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Чат между отделами"
        Height="500"
        Width="560"
        Background="#F4F4F4"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="10">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Кому (отдел): "
                       VerticalAlignment="Center" FontWeight="Bold"/>
            <ComboBox Grid.Column="1" x:Name="DepartmentBox" Height="26"/>
        </Grid>

        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="MessageBox" Height="28"
                     VerticalContentAlignment="Center"
                     KeyDown="MessageBox_KeyDown"/>
            <Button Grid.Column="1" Content="Отправить" Width="100" Height="28"
                    Margin="6,0,0,0" Background="#2E86C1" Foreground="White"
                    Click="SendButton_Click"/>
        </Grid>

        <ListBox x:Name="MessagesList" />
    </DockPanel>
</Window>
